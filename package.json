{
	"name": "nationvsc",
	"displayName": "NationVSC",
	"description": "%extension.description%",
	"publisher": "tryforge",
	"version": "1.2.8",
	"icon": "./assets/Nationdex.png",
	"main": "./out/extension.js",
	"browser": "./out/web/extension.js",
	"l10n": "./translations",
	"author": {
		"name": "xNickyDev"
	},
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"Programming Languages",
		"Visualization",
		"Other"
	],
	"extensionKind": [
		"workspace"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nationdex/nationvsc.git"
	},
	"license": "LGPL-3.0-or-later",
	"activationEvents": [
		"onLanguage:javascript",
		"onLanguage:typescript",
		"onLanguage:javascriptreact",
		"onLanguage:typescriptreact",
		"workspaceContains:.forgevsc.json",
		"workspaceContains:.vscode/.forgevsc.json"
	],
	"contributes": {
		"languages": [
			{
				"id": "forge",
				"aliases": [
					"Forge",
					"ForgeScript",
					"forgescript"
				],
				"extensions": [
					".fs"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"dark": "./assets/Nationdex.png",
					"light": "./assets/Nationdex.png"
				}
			}
		],
		"commands": [
			{
				"command": "nationvsc.createConfig",
				"title": "%command.createConfig.title%",
				"category": "NationVSC"
			},
			{
				"command": "nationvsc.reloadFunctionMetadata",
				"title": "%command.reloadFunctionMetadata.title%",
				"category": "NationVSC",
				"icon": "$(refresh)"
			},
			{
				"command": "nationvsc.searchGuides",
				"title": "%command.searchGuides.title%",
				"category": "NationVSC",
				"icon": "$(search)"
			},
			{
				"command": "nationvsc.reloadGuideMetadata",
				"title": "%command.reloadGuideMetadata.title%",
				"category": "NationVSC",
				"icon": "$(refresh)"
			},
			{
				"command": "nationvsc.openGuide",
				"title": "%command.openGuide.title%",
				"category": "NationVSC"
			},
			{
				"command": "nationvsc.previewGuide",
				"title": "%command.previewGuide.title%",
				"category": "NationVSC"
			},
			{
				"command": "nationvsc.favoriteGuide",
				"title": "%command.favoriteGuide.title%",
				"category": "NationVSC",
				"icon": "$(star-empty)"
			},
			{
				"command": "nationvsc.unfavoriteGuide",
				"title": "%command.unfavoriteGuide.title%",
				"category": "NationVSC",
				"icon": "$(star-full)"
			},
			{
				"command": "nationvsc.createGuide",
				"title": "%command.createGuide.title%",
				"category": "NationVSC",
				"icon": "$(add)"
			},
			{
				"command": "nationvsc.openGuideExternal",
				"title": "%command.openGuideExternal.title%",
				"category": "NationVSC",
				"icon": "$(link-external)"
			},
			{
				"command": "nationvsc.openExtensionSettings",
				"title": "%command.openExtensionSettings.title%",
				"category": "NationVSC",
				"icon": "$(settings)"
			}
		],
		"grammars": [
			{
				"scopeName": "forge.inject",
				"path": "./syntaxes/forge.tmLanguage.json",
				"injectTo": [
					"source.js",
					"source.ts",
					"source.jsx",
					"source.tsx"
				]
			}
		],
		"jsonValidation": [
			{
				"fileMatch": [
					".forgevsc.json",
					".vscode/.forgevsc.json"
				],
				"url": "./nationvsc.schema.json"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "nation",
					"title": "%view.guides.title%",
					"icon": "$(book)"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "nation.guidesView",
				"contents": "%view.guides.welcome%"
			}
		],
		"views": {
			"nation": [
				{
					"id": "nation.guidesView",
					"name": "%view.guides.title%",
					"icon": "$(book)"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "nationvsc.createGuide",
					"when": "view == nation.guidesView",
					"group": "navigation@0"
				},
				{
					"command": "nationvsc.searchGuides",
					"when": "view == nation.guidesView",
					"group": "navigation@1"
				},
				{
					"command": "nationvsc.reloadGuideMetadata",
					"when": "view == nation.guidesView",
					"group": "navigation@2"
				}
			],
			"view/item/context": [
				{
					"command": "nationvsc.favoriteGuide",
					"when": "view == nation.guidesView && viewItem == guide",
					"group": "inline"
				},
				{
					"command": "nationvsc.unfavoriteGuide",
					"when": "view == nation.guidesView && viewItem == guide.favorite",
					"group": "inline"
				},
				{
					"command": "nationvsc.openGuideExternal",
					"when": "view == nation.guidesView && viewItem == guide || view == nation.guidesView && viewItem == guide.favorite",
					"group": "inline@2"
				}
			],
			"commandPalette": [
				{
					"command": "nationvsc.openGuide",
					"when": "false"
				},
				{
					"command": "nationvsc.previewGuide",
					"when": "false"
				},
				{
					"command": "nationvsc.favoriteGuide",
					"when": "false"
				},
				{
					"command": "nationvsc.unfavoriteGuide",
					"when": "false"
				},
				{
					"command": "nationvsc.openGuideExternal",
					"when": "false"
				}
			]
		},
		"configurationDefaults": {
			"editor.quickSuggestions": {
				"other": true,
				"comments": false,
				"strings": true
			},
			"editor.suggestOnTriggerCharacters": true
		},
		"configuration": {
			"title": "NationVSC",
			"properties": {
				"nationvsc.global.enabledWorkspaces": {
					"order": 0,
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"uniqueItems": true,
					"scope": "machine",
					"description": "%config.global.enabledWorkspaces.description%"
				},
				"nationvsc.workspace.additionalPackages": {
					"order": 1,
					"type": "array",
					"items": {
						"type": "string"
					},
					"uniqueItems": true,
					"description": "%config.workspace.additionalPackages.description%"
				},
				"nationvsc.workspace.customFunctionPaths": {
					"order": 2,
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"uniqueItems": true,
					"description": "%config.workspace.customFunctionPaths.description%"
				},
				"nationvsc.workspace.colors.function.name": {
					"order": 10,
					"type": "string",
					"default": "#AC75FF",
					"description": "%config.workspace.colors.function.name.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.function.name.patternError%"
				},
				"nationvsc.workspace.colors.function.dollar": {
					"order": 11,
					"type": "string",
					"default": "#FE7CEB",
					"description": "%config.workspace.colors.function.dollar.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.function.dollar.patternError%"
				},
				"nationvsc.workspace.colors.function.semicolon": {
					"order": 12,
					"type": "string",
					"default": "#C586C0",
					"description": "%config.workspace.colors.function.semicolon.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.function.semicolon.patternError%"
				},
				"nationvsc.workspace.colors.arguments.condition": {
					"order": 13,
					"type": "string",
					"default": "#4FC1FF",
					"description": "%config.workspace.colors.arguments.condition.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.arguments.condition.patternError%"
				},
				"nationvsc.workspace.colors.operators.negation": {
					"order": 14,
					"type": "string",
					"default": "#4FA3FF",
					"description": "%config.workspace.colors.operators.negation.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.operators.negation.patternError%"
				},
				"nationvsc.workspace.colors.operators.silent": {
					"order": 15,
					"type": "string",
					"default": "#FF9F43",
					"description": "%config.workspace.colors.operators.silent.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.operators.silent.patternError%"
				},
				"nationvsc.workspace.colors.operators.count": {
					"order": 16,
					"type": "string",
					"default": "#33D17A",
					"description": "%config.workspace.colors.operators.count.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.operators.count.patternError%"
				},
				"nationvsc.workspace.colors.operators.countDelimiter": {
					"order": 17,
					"type": "string",
					"default": "#76E3A0",
					"description": "%config.workspace.colors.operators.countDelimiter.description%",
					"pattern": "^(?:#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?))?$",
					"patternErrorMessage": "%config.workspace.colors.operators.countDelimiter.patternError%"
				},
				"nationvsc.workspace.features.folding": {
					"order": 30,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.features.folding.description%"
				},
				"nationvsc.workspace.features.hoverInfo": {
					"order": 31,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.features.hoverInfo.description%"
				},
				"nationvsc.workspace.features.suggestions": {
					"order": 32,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.features.suggestions.description%"
				},
				"nationvsc.workspace.features.signatureHelp": {
					"order": 33,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.features.signatureHelp.description%"
				},
				"nationvsc.workspace.features.diagnostics": {
					"order": 34,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.features.diagnostics.description%"
				},
				"nationvsc.workspace.features.autocompletion": {
					"order": 35,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.features.autocompletion.description%"
				},
				"nationvsc.workspace.rpc.enabled": {
					"order": 50,
					"type": "boolean",
					"default": true,
					"description": "%config.workspace.rpc.enabled.description%"
				}
			}
		}
	},
	"scripts": {
		"web": "bunx vscode-test-web --extensionDevelopmentPath=. --port=3001",
		"trans": "bunx @vscode/l10n-dev export -o ./translations ./src",
		"publish": "dotenv -- sh -c 'bun run package && bunx ovsx publish -p $OVSX_PAT'",
		"package": "bunx @vscode/vsce package",
		"vscode:prepublish": "bun run build",
		"compile": "tsc -p ./",
		"build:web": "node scripts/esbuild.mjs",
		"build": "bun run compile && bun run build:web",
		"watch": "tsc -watch -p ./",
		"pretest": "bun run build && bun run lint:fix",
		"lint": "biome check",
		"lint:fix": "biome check --fix"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.0.0",
		"@types/vscode": "^1.105.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-web": "^0.0.81",
		"@vscode/vsce": "^3.9.2",
		"@biomejs/biome": "^2.5.4",
		"dotenv-cli": "^11.0.0",
		"esbuild": "^0.28.1",
		"ovsx": "^1.0.2"
	},
	"dependencies": {
		"@xhayper/discord-rpc": "^1.3.4",
		"typescript": "^6.0.3"
	},
	"allowScripts": {
		"@playwright/browser-chromium@1.61.0": true,
		"@vscode/vsce-sign@2.0.9": true,
		"esbuild@0.28.1": true,
		"keytar@7.9.0": true
	}
}
